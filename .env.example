# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# App URL (for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- 第三方选品API配置 ---
# TikTok Shop Open API
TIKTOK_SHOP_API_KEY=your_tiktok_shop_api_key
TIKTOK_SHOP_APP_SECRET=your_tiktok_shop_app_secret

# Amazon Product Advertising API
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_PARTNER_TAG=your_amazon_partner_tag

# Reddit API (选品数据采集)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=your_reddit_user_agent

# API源配置 (mock/tiktok/amazon/reddit)
NEXT_PUBLIC_API_SOURCE=mock
